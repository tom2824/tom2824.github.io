<section id="education">
    <div class="section-header reveal">
        <h2>Formation</h2>
        <div class="section-line"></div>
    </div>
    <div class="timeline">

        <div class="timeline-item featured reveal">
            <div class="timeline-marker edu"></div>
            <div class="timeline-content">
                <span class="timeline-badge edu">Formation</span>
                <span class="timeline-badge current">En cours</span>
                <h3>BUT Informatique — IUT de Lille</h3>
                <span class="timeline-date">2023 — 2026</span>
                <p>
                    Parcours réalisation d'applications : conception, développement,
                    validation et maintenance de logiciels.
                </p>
            </div>
        </div>

        <div class="timeline-item reveal">
            <div class="timeline-marker edu"></div>
            <div class="timeline-content">
                <span class="timeline-badge edu">Validé</span>
                <h3>BUT GEII — IUT de Lille</h3>
                <span class="timeline-date">2022 — 2023</span>
                <p>Année validée, puis réorientation vers l'informatique.</p>
            </div>
        </div>

        <div class="timeline-item reveal">
            <div class="timeline-marker edu"></div>
            <div class="timeline-content">
                <span class="timeline-badge edu">Mention Très Bien</span>
                <h3>BAC Général — Lycée Faidherbe</h3>
                <span class="timeline-date">2019 — 2022</span>
                <p>
                    Spécialités NSI + Maths. Section Anglais Euro.
                </p>
            </div>
        </div>

    </div>
</section>
