<section id="hero">
    <div class="hero-content">
        <div class="hero-image-wrapper reveal">
            <img src="/images/pp_pro2.jpg" alt="Tom NGUYEN" class="hero-image">
        </div>
        <h1 class="hero-title reveal">
            <span class="hero-greeting">Salut ! Moi c'est</span>
            <span class="hero-name">Tom NGUYEN</span>
        </h1>
        <p class="hero-subtitle reveal"><span id="age"></span> ans · Développeur · Étudiant · Auto-entrepreneur</p>
        <p class="hero-description reveal">
            Passionné d'informatique, je cherche continuellement à enrichir mes compétences
            et à contribuer à des projets stimulants.
        </p>
        <div class="hero-cta reveal">
            <a href="#projects" class="btn btn-primary">Voir mes projets</a>
            <a href="#contact" class="btn btn-outline">Me contacter</a>
        </div>
    </div>
    <div class="scroll-indicator">
        <div class="scroll-line"></div>
    </div>
</section>
